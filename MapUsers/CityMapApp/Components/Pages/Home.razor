@page "/"
@rendermode InteractiveServer

@inject HttpClient Http
@inject NavigationManager Navigation

<PageTitle>CityMapApp</PageTitle>

<section class="hero">
	<h1>Where are you from?</h1>
	<p>Add your city once and see your location represented on the live map.</p>
</section>

@if (_loading)
{
	<p>Loading...</p>
}
else if (_hasSubmitted)
{
	<div class="alert alert-info">You have already submitted your location. Thank you!</div>
}
else
{
	<EditForm Model="_request" FormName="request" OnSubmit="SubmitAsync" class="submission-form">
		<DataAnnotationsValidator />

		<div class="mb-3">
			<label class="form-label" for="city">City</label>
			<InputText id="city" @bind-Value="_request.City" class="form-control" />
			<ValidationMessage For="() => _request.City" />
		</div>

		<div class="mb-3">
			<label class="form-label" for="state">State</label>
			<InputSelect id="state" @bind-Value="_request.State" class="form-select">
				<option value="">-- Select a state --</option>
				@foreach (var s in _states)
				{
					<option value="@s">@s</option>
				}
			</InputSelect>
			<ValidationMessage For="() => _request.State" />
		</div>

		<button type="submit" class="btn btn-primary" @disabled="_submitting">@(_submitting ? "Submitting..." : "Submit")</button>
	</EditForm>

	@if (!string.IsNullOrWhiteSpace(_message))
	{
		<p class="mt-3 text-danger">@_message</p>
	}
}

@code {
	private SubmissionFormModel _request = new SubmissionFormModel();
	private string? _message;
	private bool _loading = true;
	private bool _hasSubmitted = false;
	private bool _submitting = false;

	private static readonly string[] _states =
	[
		"AL", "AK", "AZ", "AR", "CA", "CO", "CT", "DE", "FL", "GA",
		"HI", "ID", "IL", "IN", "IA", "KS", "KY", "LA", "ME", "MD",
		"MA", "MI", "MN", "MS", "MO", "MT", "NE", "NV", "NH", "NJ",
		"NM", "NY", "NC", "ND", "OH", "OK", "OR", "PA", "RI", "SC",
		"SD", "TN", "TX", "UT", "VT", "VA", "WA", "WV", "WI", "WY",
		"DC"
	];

	protected override async Task OnInitializedAsync()
	{
	   try
	   {
		   var response = await Http.GetFromJsonAsync<SubmissionStatusResponse>("/api/submissions/me");
		   _hasSubmitted = response?.HasSubmitted ?? false;
	   }
	   catch (HttpRequestException ex)
	   {
		   _message = "Could not check submission status. Please try again later.";
		   // Optionally log ex
	   }
	   finally
	   {
		   _loading = false;
	   }
	}

	private async Task SubmitAsync()
	{
		_message = null;

		// Validate the form data
		if (string.IsNullOrWhiteSpace(_request.City) || string.IsNullOrWhiteSpace(_request.State))
		{
			_message = "City and State are required.";
			return;
		}

		_submitting = true;

		try
		{
			var submitRequest = new SubmissionRequest(_request.City, _request.State);
			var response = await Http.PostAsJsonAsync("/api/submissions", submitRequest);
			
			if (response == null)
			{
				_message = "No response from server.";
				return;
			}

			var payload = await response.Content.ReadFromJsonAsync<SubmissionResponse>();

			if (payload == null)
			{
				_message = "Server returned an invalid response.";
				return;
			}

			if (payload.Success)
			{
				Navigation.NavigateTo("/map", replace: true);
				return;
			}

			_message = payload.Message ?? "Unable to submit right now.";
		}
		catch (Exception ex)
		{
			_message = $"Error: {ex.Message}";
		}
		finally
		{
			_submitting = false;
		}
	}

	private sealed class SubmissionFormModel
	{
		[System.ComponentModel.DataAnnotations.Required]
		[System.ComponentModel.DataAnnotations.StringLength(maximumLength: 50)]
		public string City { get; set; } = string.Empty;

		[System.ComponentModel.DataAnnotations.Required]
		[System.ComponentModel.DataAnnotations.StringLength(maximumLength: 2)]
		public string State { get; set; } = string.Empty;
	}
}
